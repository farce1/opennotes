---
import { Github } from '@lucide/astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="fixed top-0 z-50 w-full border-b border-[var(--sl-color-hairline-light)] bg-[var(--sl-color-bg)]/80 backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="text-xl font-bold text-[var(--sl-color-text-accent)] no-underline">
      openNotes
    </a>
    <div class="flex items-center gap-4 sm:gap-6">
      <a
        href="/getting-started/"
        class="text-sm font-medium text-[var(--sl-color-gray-2)] no-underline transition-colors hover:text-[var(--sl-color-text)]"
      >
        Docs
      </a>
      <a
        href="https://github.com/nicodeforge/opennotes"
        class="text-[var(--sl-color-gray-2)] transition-colors hover:text-[var(--sl-color-text)]"
        aria-label="GitHub"
      >
        <Github class="h-5 w-5" />
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>
