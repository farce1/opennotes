---
import { FileText, Mic, Sparkles } from '@lucide/astro';

const steps = [
  {
    number: '1',
    icon: Mic,
    title: 'Record',
    description:
      'Click record and start your meeting. openNotes captures audio from your microphone or system audio.',
  },
  {
    number: '2',
    icon: FileText,
    title: 'Transcribe',
    description:
      'Speech is transcribed in real-time using Parakeet TDT, a state-of-the-art model running locally on your machine.',
  },
  {
    number: '3',
    icon: Sparkles,
    title: 'Summarize',
    description:
      'An AI model distills your transcript into structured meeting notes with key points, decisions, and action items.',
  },
];
---

<section class="bg-[var(--sl-color-bg-nav)] py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-bold text-[var(--sl-color-white)] sm:text-4xl">How it works</h2>
      <p class="mt-4 text-lg text-[var(--sl-color-gray-2)]">Three steps. Zero cloud. Complete privacy.</p>
    </div>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3 lg:gap-12">
      {
        steps.map(({ number, icon: Icon, title, description }, i) => (
          <div class="relative text-center">
            <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-[var(--sl-color-accent)]/10">
              <Icon class="h-8 w-8 text-[var(--sl-color-accent)]" />
            </div>
            <div class="absolute -top-2 left-1/2 flex h-8 w-8 -translate-x-[3.5rem] items-center justify-center rounded-full bg-[var(--sl-color-accent)] text-sm font-bold text-white">
              {number}
            </div>
            <h3 class="text-xl font-semibold text-[var(--sl-color-white)]">{title}</h3>
            <p class="mt-3 leading-relaxed text-[var(--sl-color-gray-2)]">{description}</p>
            {i < steps.length - 1 && (
              <div class="absolute left-[calc(50%+3rem)] top-8 hidden h-px w-[calc(100%-6rem)] bg-[var(--sl-color-hairline-light)] md:block" />
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
