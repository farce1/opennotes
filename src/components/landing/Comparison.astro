---
import { Check, X } from '@lucide/astro';

const features = [
  { label: 'Runs locally (no cloud)', openNotes: true, cloud: false },
  { label: 'No subscription fees', openNotes: true, cloud: false },
  { label: 'No bot joins your meetings', openNotes: true, cloud: false },
  { label: 'Works offline', openNotes: true, cloud: false },
  { label: 'Open-source', openNotes: true, cloud: false },
  { label: 'Data stays on your machine', openNotes: true, cloud: false },
  { label: 'AI-powered summaries', openNotes: true, cloud: true },
  { label: 'Real-time transcription', openNotes: true, cloud: true },
];
---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-bold text-[var(--sl-color-white)] sm:text-4xl">Why openNotes?</h2>
      <p class="mt-4 text-lg text-[var(--sl-color-gray-2)]">
        See how openNotes compares to cloud-based alternatives like Otter.ai and Fireflies.
      </p>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b-2 border-[var(--sl-color-hairline-light)]">
            <th class="px-4 py-4 text-left text-sm font-semibold text-[var(--sl-color-gray-2)]">Feature</th>
            <th class="px-4 py-4 text-center text-sm font-semibold text-[var(--sl-color-accent)]">openNotes</th>
            <th class="px-4 py-4 text-center text-sm font-semibold text-[var(--sl-color-gray-3)]">Cloud alternatives</th>
          </tr>
        </thead>
        <tbody>
          {
            features.map(({ label, openNotes, cloud }) => (
              <tr class="border-b border-[var(--sl-color-hairline-light)]">
                <td class="px-4 py-4 text-sm text-[var(--sl-color-text)]">{label}</td>
                <td class="px-4 py-4 text-center">
                  {openNotes ? (
                    <Check class="mx-auto h-5 w-5 text-green-500" />
                  ) : (
                    <X class="mx-auto h-5 w-5 text-red-400" />
                  )}
                </td>
                <td class="px-4 py-4 text-center">
                  {cloud ? (
                    <Check class="mx-auto h-5 w-5 text-green-500" />
                  ) : (
                    <X class="mx-auto h-5 w-5 text-red-400" />
                  )}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
