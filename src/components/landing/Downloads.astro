---
import { Laptop, Monitor, Terminal } from '@lucide/astro';

const platforms = [
  {
    icon: Laptop,
    name: 'macOS',
    description: 'Apple Silicon & Intel',
    file: '.dmg',
  },
  {
    icon: Monitor,
    name: 'Windows',
    description: 'Windows 10+',
    file: '.msi',
  },
  {
    icon: Terminal,
    name: 'Linux',
    description: 'AppImage',
    file: '.AppImage',
  },
];

const releasesUrl = 'https://github.com/nicodeforge/opennotes/releases';
---

<section class="bg-[var(--sl-color-bg-nav)] py-20 sm:py-28">
  <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-[var(--sl-color-white)] sm:text-4xl">Download openNotes</h2>
    <p class="mt-4 text-lg text-[var(--sl-color-gray-2)]">
      Free and open-source. Available for all major platforms.
    </p>
    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-3">
      {
        platforms.map(({ icon: Icon, name, description, file }) => (
          <a
            href={releasesUrl}
            class="group flex flex-col items-center gap-3 rounded-2xl border-2 border-[var(--sl-color-hairline-light)] bg-[var(--sl-color-bg)] p-6 no-underline transition-all hover:border-[var(--sl-color-accent)]"
          >
            <Icon class="h-10 w-10 text-[var(--sl-color-gray-2)] transition-colors group-hover:text-[var(--sl-color-accent)]" />
            <div>
              <p class="text-lg font-semibold text-[var(--sl-color-white)]">{name}</p>
              <p class="text-sm text-[var(--sl-color-gray-3)]">
                {description} ({file})
              </p>
            </div>
          </a>
        ))
      }
    </div>
    <p class="mt-8 text-sm text-[var(--sl-color-gray-3)]">
      All downloads available on{' '}
      <a href={releasesUrl} class="text-[var(--sl-color-accent)] hover:underline">GitHub Releases</a>.
    </p>
  </div>
</section>
